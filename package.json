{
  "name": "@ai-setting/agent-bounty",
  "version": "0.4.0",
  "type": "module",
  "description": "AI Agent Bounty System \u2014 Task publishing, grabbing, and communication platform. v0.4.0: bounty com config command removed; BOUNTY_TOKEN_CHECK_ENABLED env var controls API JWT enforcement (default OFF); Aligned with roy-agent v1.5.104+ EventSourceConfig.systemPrompt (Phase 3).",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bounty": {
      "import": "./dist/lib/bounty/index.js",
      "types": "./dist/lib/bounty/index.d.ts"
    },
    "./mail": {
      "import": "./dist/lib/mail/index.js",
      "types": "./dist/lib/mail/index.d.ts"
    },
    "./com": {
      "import": "./dist/lib/com/index.js",
      "types": "./dist/lib/com/index.d.ts"
    },
    "./cli": {
      "import": "./dist/bin/bounty.js"
    },
    "./plugin": {
      "import": "./dist/plugin/index.js",
      "types": "./dist/plugin/index.d.ts"
    }
  },
  "bin": {
    "bounty": "./dist/bin/bounty.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "src/**/*.ts",
    "roy-plugin.js"
  ],
  "scripts": {
    "build": "bun run build:cli && bun run build:bin && bun run build:server && bun run build:plugin",
    "build:cli": "bun build ./src/cli/cli.ts --outdir=./dist --target=bun --external @ai-setting/roy-agent-cli --external @ai-setting/roy-agent-core",
    "build:bin": "bun build ./src/bin/bounty.ts --outdir=./dist/bin --target=bun --external @ai-setting/roy-agent-cli --external @ai-setting/roy-agent-core",
    "build:server": "bun build ./src/server/server.ts --outdir=./dist/server --target=bun",
    "build:plugin": "bun build ./src/plugin/index.ts --outdir=./dist/plugin --target=bun",
    "build:standalone": "bun run scripts/build-standalone.ts",
    "build:standalone:all": "bun run scripts/build-standalone.ts --all",
    "build:standalone:publish": "bun run scripts/build-standalone.ts --publish",
    "build:standalone:all:publish": "bun run scripts/build-standalone.ts --all --publish",
    "build:standalone:dry-run": "bun run scripts/build-standalone.ts --dry-run",
    "build:standalone:all:dry-run": "bun run scripts/build-standalone.ts --all --dry-run",
    "server": "bun run dist/server/server.js",
    "dev": "bun run src/bin/bounty.ts",
    "im:server": "bun run scripts/start-im-server.ts",
    "test": "BOUNTY_MAIL_DRY_RUN=1 bun test --isolate",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-setting/roy-agent-cli": "^1.5.102",
    "@ai-setting/roy-agent-coder-harness": "^1.5.48",
    "@ai-setting/roy-agent-core": "^1.5.98",
    "@types/ws": "^8.18.1",
    "chalk": "^5.3.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "nodemailer": "^8.0.7",
    "uuid": "^9.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^9.0.7",
    "@types/yargs": "^17.0.32",
    "bun-types": "^1.3.11",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-setting/ai-agent-bounty.git"
  },
  "keywords": [
    "ai-agent",
    "bounty",
    "task",
    "reward",
    "mail",
    "communication",
    "escrow",
    "smtp",
    "token-toggle"
  ],
  "author": "ai-setting",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ai-setting/ai-agent-bounty/issues"
  }
}