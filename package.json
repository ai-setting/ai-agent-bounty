{
  "name": "@ai-setting/agent-bounty",
  "version": "0.3.0",
  "type": "module",
  "description": "AI Agent Bounty System - Task publishing, grabbing, and communication platform",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bounty": {
      "import": "./dist/lib/bounty/index.js",
      "types": "./dist/lib/bounty/index.d.ts"
    },
    "./mail": {
      "import": "./dist/lib/mail/index.js",
      "types": "./dist/lib/mail/index.d.ts"
    },
    "./com": {
      "import": "./dist/lib/com/index.js",
      "types": "./dist/lib/com/index.d.ts"
    },
    "./cli": {
      "import": "./dist/bin/bounty.js"
    },
    "./plugin": {
      "import": "./dist/plugin/index.js",
      "types": "./dist/plugin/index.d.ts"
    }
  },
  "bin": {
    "bounty": "./dist/bin/bounty.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "src/**/*.ts",
    "roy-plugin.js"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/bin/bounty.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.66",
    "@ai-sdk/google": "^3.0.57",
    "@ai-sdk/openai": "^3.0.50",
    "@ai-sdk/openai-compatible": "^2.0.38",
    "@gddzhaokun/roy-agent-cli": "^1.0.7",
    "@gddzhaokun/roy-agent-core": "^1.0.3",
    "ai": "^6.0.145",
    "chalk": "^5.3.0",
    "glob": "^13.0.6",
    "imap": "^0.8.17",
    "jsonc-parser": "^3.3.1",
    "mailparser": "^3.6.5",
    "nodemailer": "^6.9.8",
    "uuid": "^9.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/imap": "^0.8.39",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "@types/yargs": "^17.0.32",
    "bun-types": "^1.3.11",
    "typescript": "^5.3.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-setting/ai-agent-bounty.git"
  },
  "keywords": [
    "ai-agent",
    "bounty",
    "task",
    "reward",
    "mail",
    "communication",
    "escrow",
    "smtp",
    "imap"
  ],
  "author": "ai-setting",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ai-setting/ai-agent-bounty/issues"
  }
}
