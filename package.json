{
  "name": "@ai-setting/agent-bounty",
  "version": "0.1.0",
  "type": "module",
  "description": "AI Agent Bounty System - Task publishing, grabbing, and communication platform",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bounty": {
      "import": "./dist/lib/bounty/index.js",
      "types": "./dist/lib/bounty/index.d.ts"
    },
    "./mail": {
      "import": "./dist/lib/mail/index.js",
      "types": "./dist/lib/mail/index.d.ts"
    },
    "./cli": {
      "import": "./dist/bin/bounty.js"
    }
  },
  "bin": {
    "agent-bounty": "./dist/bin/bounty.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "src/**/*.ts"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "bun run --watch src/bin/bounty.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@gddzhaokun/roy-agent-core": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.3.0",
    "imap": "^0.8.17",
    "mailparser": "^3.6.5",
    "nodemailer": "^6.9.8",
    "uuid": "^9.0.0",
    "yargs": "^17.7.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/imap": "^0.8.39",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.7",
    "@types/yargs": "^17.0.32",
    "bun-types": "^1.3.11",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-setting/ai-agent-bounty.git"
  },
  "keywords": [
    "ai-agent",
    "bounty",
    "task",
    "reward",
    "mail",
    "communication",
    "escrow"
  ],
  "author": "ai-setting",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ai-setting/ai-agent-bounty/issues"
  }
}
