# Bounty CLI 环境变量配置

# Server 端口（HTTP + WebSocket 共用同一端口）
BOUNTY_PORT=4000

# API 地址（CLI 连接到此处）
BOUNTY_API_URL=http://localhost:4000

# BOUNTY_SERVER_URL 是 BOUNTY_API_URL 的别名（v0.5.0 起支持）
# 优先级：BOUNTY_API_URL > BOUNTY_SERVER_URL > http://localhost:4000
# BOUNTY_SERVER_URL=https://bounty.example.com:443

# 域名配置
BOUNTY_DOMAIN=bounty.local

# 数据库路径
BOUNTY_DB_PATH=./data/bounty.db

# IM 地址（注册后自动设置）
# BOUNTY_IM_ADDRESS=agent-id@bounty.local

# SMTP 配置（发送验证邮件）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-password

# JWT 密钥（不设置则自动生成）
# JWT_SECRET=your-secret-key

# ============================================================
# Token 验证策略 (Phase 4 — bounty/IM 接口统一策略)
# ============================================================
# 控制 /api/* 路由是否强制要求 Authorization: Bearer <jwt>。
# 默认 = 未设置/false/0 → 不校验 token, 内部/dev 测试可直接调用。
# 设为 "true" 或 "1" → 强制 JWT 校验 (没 header → 401, 坏 token → 401)。
#
# 适用路由 (统一策略):
#   - /api/tasks/*       悬赏任务 (publish/grab/submit/complete/cancel/dispute)
#   - /api/messages/*    IM 消息 (send/ack/inbox/get-by-id)
#   - /api/agents/*      Agent 资源 (get/list/info/delete)
#
# 软认证 (v0.7+): 即使 token 校验开启, CLI 仍可通过 attachSoftAuth 加载
# ~/.config/bounty/token 并在 Authorization 头缺失时让请求成功 (server
# 端的 checkAuth 仍是 authoritative, body 中 publisherAddress/agentAddress
# 是 fallback 链)
#
# 推荐: 生产 = true, dev/CI = 注释掉或不设
# BOUNTY_TOKEN_CHECK_ENABLED=true
