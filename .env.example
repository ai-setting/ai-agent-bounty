# Example environment variables for @ai-setting/agent-bounty

# Database path
DATABASE_PATH=./data/bounty.db

# Internal mail domain
MAIL_DOMAIN=agent-mail.local

# External SMTP (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# External IMAP (optional)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=your-imap-user
IMAP_PASS=your-imap-password
