# Example environment variables for @ai-setting/agent-bounty

# Database path
DATABASE_PATH=./data/bounty.db

# Internal mail domain
MAIL_DOMAIN=agent-mail.local

# External SMTP (optional) - for sending emails to external addresses
SMTP_HOST=smtp.163.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-163-email
SMTP_PASS=your-163-password
SMTP_FROM=your-163-email@163.com

# External IMAP (optional) - for receiving emails from external accounts
IMAP_HOST=imap.163.com
IMAP_PORT=993
IMAP_TLS=true
IMAP_USER=your-163-email@163.com
IMAP_PASS=your-163-password
IMAP_POLL_INTERVAL=30000  # milliseconds (30 seconds)
IMAP_ENABLED=true
